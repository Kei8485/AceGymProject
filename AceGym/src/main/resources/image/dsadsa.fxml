<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="867.0" styleClass="main-content-bg"
    xmlns="http://javafx.com/javafx/17.0.12"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="codes.acegym.ViewMembersController">
    <stylesheets>
        <URL value="@../../Css/ViewMembers.css" />
    </stylesheets>
    <children>
        <VBox spacing="20.0"
            AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0"
            AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>

                <!-- ── Page Header ── -->
                <HBox alignment="CENTER_LEFT" spacing="16.0">
                    <children>
                        <!-- Icon Badge -->
                        <StackPane styleClass="header-icon-badge" minWidth="52" minHeight="52" maxWidth="52" maxHeight="52">
                            <children>
                                <ImageView fitHeight="26.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../image/members-icon.png" /></image>
                                </ImageView>
                            </children>
                        </StackPane>
                        <!-- Title block -->
                        <VBox spacing="2.0">
                            <children>
                                <Label styleClass="page-eyebrow" text="GYM MANAGEMENT" />
                                <Label styleClass="page-title" text="Gym Clients" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- ── Main Card ── -->
                <VBox spacing="16.0" styleClass="card-bg" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>

                        <!-- ── Toolbar ── -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label styleClass="card-title" text="Members List" />
                                        <Label fx:id="memberCountLabel" styleClass="card-subtitle" text="0 members total" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <!-- Show Entities -->
                                <Label styleClass="toolbar-label" text="Show" />
                                <ComboBox fx:id="entriesCombo"
                                    prefHeight="36.0" prefWidth="80.0"
                                    styleClass="combo-field"
                                    promptText="10" />

                                <!-- Search -->
                                <StackPane alignment="CENTER_LEFT">
                                    <children>
                                        <TextField fx:id="searchField"
                                            prefHeight="36.0" prefWidth="220.0"
                                            promptText="Search members..."
                                            styleClass="search-field" />
                                        <ImageView fitHeight="15.0" fitWidth="15.0"
                                            pickOnBounds="true" preserveRatio="true"
                                            mouseTransparent="true">
                                            <image><Image url="@../../image/magnifying-glass-solid.png" /></image>
                                            <StackPane.margin><Insets right="12.0" /></StackPane.margin>
                                        </ImageView>
                                    </children>
                                    <HBox.margin><Insets left="4.0" /></HBox.margin>
                                </StackPane>

                                <!-- Add Member Button -->
                                <Button fx:id="addMemberBtn"
                                    styleClass="btn-add"
                                    text="+ Add Member"
                                    prefHeight="36.0" />
                            </children>
                        </HBox>

                        <!-- ── Divider ── -->
                        <Separator styleClass="card-divider" />

                        <!-- ── Table ── -->
                        <TableView fx:id="membersTable"
                            styleClass="members-table"
                            VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn prefWidth="200.0" text="Name" fx:id="nameCol" />
                                <TableColumn prefWidth="140.0" text="Member ID" fx:id="idCol" />
                                <TableColumn prefWidth="150.0" text="Date Enrolled" fx:id="enrolledCol" />
                                <TableColumn prefWidth="150.0" text="Expiration" fx:id="expirationCol" />
                                <TableColumn prefWidth="80.0"  text="Status" fx:id="statusCol" />
                                <TableColumn prefWidth="100.0" text="Actions" fx:id="actionsCol" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <!-- ── Footer / Pagination ── -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label fx:id="paginationInfoLabel"
                                    styleClass="pagination-info"
                                    text="Showing 0 – 0 of 0 entries" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="prevBtn"
                                    styleClass="btn-page-prev"
                                    text="← Prev"
                                    prefHeight="34.0" prefWidth="90.0" />
                                <Button fx:id="nextBtn"
                                    styleClass="btn-page-next"
                                    text="Next →"
                                    prefHeight="34.0" prefWidth="90.0" />
                            </children>
                        </HBox>

                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
