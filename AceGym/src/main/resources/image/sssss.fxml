<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="867.0" styleClass="main-content-bg"
    xmlns="http://javafx.com/javafx/17.0.12"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="codes.acegym.PlanController">
    <stylesheets>
        <URL value="@../../Css/Plan.css" />
    </stylesheets>
    <children>
        <ScrollPane fitToWidth="true" styleClass="page-scroll"
            AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0"
            AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="20.0">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="24.0" />
                    </padding>
                    <children>

                        <!-- ── Page Header ── -->
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <StackPane styleClass="header-icon-badge" minWidth="52" minHeight="52" maxWidth="52" maxHeight="52">
                                    <children>
                                        <Label styleClass="header-icon-label" text="#" />
                                    </children>
                                </StackPane>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label styleClass="page-eyebrow" text="GYM CONFIGURATION" />
                                        <Label styleClass="page-title" text="Settings" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- ════════════════════════════════════════ -->
                        <!-- SECTION 1 — PAYMENT TYPE                -->
                        <!-- ════════════════════════════════════════ -->
                        <VBox spacing="14.0" styleClass="section-card">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <!-- Section Header -->
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <StackPane styleClass="section-icon-badge" minWidth="36" minHeight="36" maxWidth="36" maxHeight="36">
                                            <children>
                                                <Label styleClass="section-icon-label" text="₱" />
                                            </children>
                                        </StackPane>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label styleClass="section-title" text="Payment Type" />
                                                <Label styleClass="section-subtitle" text="Add and manage membership plan types" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Divider -->
                                <Region styleClass="card-divider" minHeight="1.0" maxHeight="1.0" />

                                <!-- Form Row -->
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="field-label" text="Plan Name" />
                                                <TextField fx:id="planNameField"
                                                    styleClass="input-field"
                                                    promptText="e.g. Monthly, Annual..."
                                                    prefHeight="38.0" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="6.0" prefWidth="200.0">
                                            <children>
                                                <Label styleClass="field-label" text="Period (months)" />
                                                <TextField fx:id="planPeriodField"
                                                    styleClass="input-field"
                                                    promptText="e.g. 1, 3, 12"
                                                    prefHeight="38.0" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Buttons -->
                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="addPlanBtn" styleClass="btn-primary" text="+ Add Plan" prefHeight="36.0" />
                                        <Button fx:id="editPlanBtn" styleClass="btn-secondary" text="Edit" prefHeight="36.0" />
                                    </children>
                                </HBox>

                                <!-- Table Toolbar -->
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label styleClass="toolbar-label" text="Show" />
                                        <ComboBox fx:id="planEntriesCombo"
                                            styleClass="combo-field"
                                            prefHeight="34.0" prefWidth="75.0"
                                            promptText="10" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="planSearchField"
                                                    styleClass="search-field"
                                                    promptText="Search plans..."
                                                    prefHeight="34.0" prefWidth="210.0" />
                                                <ImageView fitHeight="14.0" fitWidth="14.0" pickOnBounds="true" preserveRatio="true" mouseTransparent="true">
                                                    <image><Image url="@../../image/magnifying-glass-solid.png" /></image>
                                                    <StackPane.margin><Insets right="11.0" /></StackPane.margin>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>

                                <!-- Table -->
                                <TableView fx:id="planTable" styleClass="section-table" prefHeight="200.0" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn prefWidth="280.0" text="Plan Name" fx:id="planNameCol" />
                                        <TableColumn prefWidth="200.0" text="Period" fx:id="planPeriodCol" />
                                        <TableColumn prefWidth="120.0" text="Actions" fx:id="planActionsCol" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>

                            </children>
                        </VBox>

                        <!-- ════════════════════════════════════════ -->
                        <!-- SECTION 2 — TRAINING CATEGORY           -->
                        <!-- ════════════════════════════════════════ -->
                        <VBox spacing="14.0" styleClass="section-card">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <!-- Section Header -->
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <StackPane styleClass="section-icon-badge" minWidth="36" minHeight="36" maxWidth="36" maxHeight="36">
                                            <children>
                                                <Label styleClass="section-icon-label" text="T" />
                                            </children>
                                        </StackPane>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label styleClass="section-title" text="Training Category" />
                                                <Label styleClass="section-subtitle" text="Categorize training types and set pricing" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Divider -->
                                <Region styleClass="card-divider" minHeight="1.0" maxHeight="1.0" />

                                <!-- Form Row -->
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="field-label" text="Category Name" />
                                                <TextField fx:id="categoryNameField"
                                                    styleClass="input-field"
                                                    promptText="e.g. Lifting, Martial Arts..."
                                                    prefHeight="38.0" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="6.0" prefWidth="200.0">
                                            <children>
                                                <Label styleClass="field-label" text="Amount (₱)" />
                                                <TextField fx:id="categoryAmountField"
                                                    styleClass="input-field"
                                                    promptText="0.00"
                                                    prefHeight="38.0" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Buttons -->
                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="addCategoryBtn" styleClass="btn-primary" text="+ Add Category" prefHeight="36.0" />
                                        <Button fx:id="editCategoryBtn" styleClass="btn-secondary" text="Edit" prefHeight="36.0" />
                                    </children>
                                </HBox>

                                <!-- Table Toolbar -->
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label styleClass="toolbar-label" text="Show" />
                                        <ComboBox fx:id="categoryEntriesCombo"
                                            styleClass="combo-field"
                                            prefHeight="34.0" prefWidth="75.0"
                                            promptText="10" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="categorySearchField"
                                                    styleClass="search-field"
                                                    promptText="Search categories..."
                                                    prefHeight="34.0" prefWidth="210.0" />
                                                <ImageView fitHeight="14.0" fitWidth="14.0" pickOnBounds="true" preserveRatio="true" mouseTransparent="true">
                                                    <image><Image url="@../../image/magnifying-glass-solid.png" /></image>
                                                    <StackPane.margin><Insets right="11.0" /></StackPane.margin>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>

                                <!-- Table -->
                                <TableView fx:id="categoryTable" styleClass="section-table" prefHeight="200.0" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn prefWidth="300.0" text="Category Name" fx:id="categoryNameCol" />
                                        <TableColumn prefWidth="160.0" text="Amount" fx:id="categoryAmountCol" />
                                        <TableColumn prefWidth="120.0" text="Actions" fx:id="categoryActionsCol" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>

                            </children>
                        </VBox>

                        <!-- ════════════════════════════════════════ -->
                        <!-- SECTION 3 — CLIENT DISCOUNT             -->
                        <!-- ════════════════════════════════════════ -->
                        <VBox spacing="14.0" styleClass="section-card">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <!-- Section Header -->
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <StackPane styleClass="section-icon-badge" minWidth="36" minHeight="36" maxWidth="36" maxHeight="36">
                                            <children>
                                                <Label styleClass="section-icon-label" text="%" />
                                            </children>
                                        </StackPane>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label styleClass="section-title" text="Client Discount" />
                                                <Label styleClass="section-subtitle" text="Set discount rates for Member and Non-Member clients" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Divider -->
                                <Region styleClass="card-divider" minHeight="1.0" maxHeight="1.0" />

                                <!-- Info note -->
                                <HBox styleClass="info-banner" spacing="8.0" alignment="CENTER_LEFT">
                                    <padding><Insets bottom="10.0" left="12.0" right="12.0" top="10.0" /></padding>
                                    <children>
                                        <Label styleClass="info-banner-icon" text="i" />
                                        <Label styleClass="info-banner-text"
                                            text="Only the discount percentage can be changed. Client types (Member, Non-Member) are fixed." />
                                    </children>
                                </HBox>

                                <!-- Form Row -->
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="field-label" text="Client Type" />
                                                <ComboBox fx:id="clientTypeCombo"
                                                    styleClass="input-combo"
                                                    promptText="Select client type"
                                                    prefHeight="38.0"
                                                    maxWidth="Infinity"
                                                    HBox.hgrow="ALWAYS" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="6.0" prefWidth="200.0">
                                            <children>
                                                <Label styleClass="field-label" text="Discount (%)" />
                                                <TextField fx:id="discountField"
                                                    styleClass="input-field"
                                                    promptText="e.g. 30"
                                                    prefHeight="38.0" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Buttons -->
                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="saveDiscountBtn" styleClass="btn-primary" text="Save Changes" prefHeight="36.0" />
                                        <Button fx:id="cancelDiscountBtn" styleClass="btn-secondary" text="Cancel" prefHeight="36.0" />
                                    </children>
                                </HBox>

                                <!-- Table -->
                                <TableView fx:id="discountTable" styleClass="section-table" prefHeight="150.0">
                                    <columns>
                                        <TableColumn prefWidth="300.0" text="Client Type" fx:id="clientTypeCol" />
                                        <TableColumn prefWidth="160.0" text="Discount" fx:id="discountCol" />
                                        <TableColumn prefWidth="120.0" text="Actions" fx:id="discountActionsCol" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
