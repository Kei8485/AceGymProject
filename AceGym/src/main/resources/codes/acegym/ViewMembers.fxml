<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="867.0" styleClass="main-content-bg" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.ViewMembersController">
    <children>
        <VBox spacing="20.0" stylesheets="@../../Css/ViewMembers.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <Label prefHeight="47.0" prefWidth="370.0" styleClass="active-page-title" stylesheets="@../../Css/ViewMembers.css" text="Ace Fitness Gym Clients" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>

                <VBox spacing="20.0" styleClass="card-bg" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Label stylesheets="@../../Css/ViewMembers.css" text="Gym Members" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label styleClass="text-header-smaller" text="Show Entities" textFill="#f5f4f4" />
                                <ComboBox prefHeight="29.0" prefWidth="79.0" stylesheets="@../../Css/ViewMembers.css" />
                                <StackPane alignment="CENTER_RIGHT">
                                    <children>
                                        <TextField prefHeight="35.0" prefWidth="200.0" promptText="Search" styleClass="search-field" />
                                        <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                            <image><Image url="@../../image/magnifying-glass-solid.png" /></image>
                                            <StackPane.margin><Insets right="10.0" /></StackPane.margin>
                                        </ImageView>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>

                        <TableView fx:id="membersTable" stylesheets="@../../Css/ViewMembers.css" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn prefWidth="150.0" text="Name" />
                                <TableColumn prefWidth="120.0" text="Member ID" />
                                <TableColumn prefWidth="130.0" text="Date Enrolled" />
                                <TableColumn prefWidth="130.0" text="Date Expiration" />
                                <TableColumn prefWidth="100.0" text="Actions" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
   <stylesheets>
      <URL value="@../../Css/ViewMembers.css" />
      <URL value="@../../Css/ViewMembers.css" />
   </stylesheets>
</AnchorPane>
