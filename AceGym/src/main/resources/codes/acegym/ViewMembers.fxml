<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane maxWidth="1200.0" prefHeight="700.0" prefWidth="1100.0" styleClass="main-content-bg"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="codes.acegym.Controllers.ViewMembersController">
    <stylesheets>
        <URL value="@../../Css/ViewMembers.css" />
    </stylesheets>
    <children>
        <VBox spacing="20.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>

                <!-- ── Page Header ── -->
                <HBox alignment="CENTER_LEFT" spacing="16.0">
                    <children>
                        <StackPane maxHeight="52" maxWidth="52" minHeight="52" minWidth="52"
                                   styleClass="header-icon-badge">
                            <children>
                                <ImageView fitHeight="45.0" fitWidth="44.0"
                                           pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../image/hand-fist-solid.png" /></image>
                                </ImageView>
                            </children>
                        </StackPane>
                        <VBox spacing="2.0">
                            <children>
                                <Label styleClass="page-eyebrow" text="GYM MANAGEMENT">
                                    <padding><Insets bottom="-10.0" top="-10.0" /></padding>
                                </Label>
                                <Label styleClass="page-title" text="Gym Clients" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- ── Main Card ── -->
                <VBox spacing="16.0" styleClass="card-bg" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>

                        <!-- ── Toolbar ── -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label styleClass="card-title" text="Members List" />
                                        <Label fx:id="memberCountLabel" styleClass="card-subtitle"
                                               text="Loading…" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <!-- View Filter -->
                                <Label styleClass="toolbar-label" text="View" />
                                <ComboBox fx:id="entriesCombo" prefHeight="36.0" prefWidth="160.0"
                                          promptText="All Clients" styleClass="combo-field" />

                                <!-- Search -->
                                <StackPane alignment="CENTER_LEFT" prefHeight="37.0" prefWidth="220.0">
                                    <children>
                                        <TextField fx:id="searchField" prefHeight="36.0" prefWidth="220.0"
                                                   promptText="Search clients…" styleClass="search-field" />
                                        <ImageView fitHeight="14.0" fitWidth="14.0"
                                                   mouseTransparent="true" pickOnBounds="true" preserveRatio="true">
                                            <image><Image url="@../../image/magnifying-glass-solid.png" /></image>
                                            <StackPane.margin><Insets left="8.0" /></StackPane.margin>
                                        </ImageView>
                                    </children>
                                    <HBox.margin><Insets left="4.0" /></HBox.margin>
                                </StackPane>

                                <!-- Refresh -->
                                <Button fx:id="refreshBtn" prefHeight="36.0"
                                        styleClass="btn-search" text="↻ Refresh" />
                            </children>
                        </HBox>

                        <!-- ── Divider ── -->
                        <Region maxHeight="1.0" minHeight="1.0" styleClass="card-divider" />

                        <!-- ── Table (columns injected by controller) ── -->
                        <TableView fx:id="membersTable" styleClass="members-table" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <placeholder>
                                <Label text="No clients found." />
                            </placeholder>
                        </TableView>

                        <!-- ── Footer ── -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label fx:id="hintLabel" styleClass="card-subtitle"
                                       text="💡 Double-click any row for full client details" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="filteredCountLabel" styleClass="card-subtitle" text="" />
                            </children>
                        </HBox>

                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
