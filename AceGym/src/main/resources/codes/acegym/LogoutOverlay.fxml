<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="300.0" prefWidth="488.0" styleClass="logout-card" stylesheets="@../../Css/styles2.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.Controllers.LogoutOverlayController">
    <children>
        <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <AnchorPane prefHeight="262.0" prefWidth="150.0">
                    <children>
                        <ImageView fx:id="logoutIcon" fitHeight="100.0" fitWidth="100.0" layoutX="25.0" layoutY="81.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../../image/logout%20(1).png" />
                            </image>
                        </ImageView>
                    </children>
                </AnchorPane>

                <VBox alignment="CENTER_LEFT" prefWidth="320.0" spacing="10.0">
                    <children>
                        <Label fx:id="headerLabel" styleClass="logout-headerText" text="Confirm Logout" wrapText="true">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>

                        <Label fx:id="subHeaderLabel" maxWidth="300.0" styleClass="logout-sub-header" text="Are you sure you want to logout from the Ace Fitness Gym system?" textFill="#f7f5f5e4" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>

                        <HBox fx:id="buttonBox" alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" styleClass="hbox-btn-spacing">
                            <children>
                                <Button mnemonicParsing="false" onAction="#cancelLogout" prefHeight="40.0" prefWidth="110.0" styleClass="logout-cancel-btn" text="Cancel" />
                                <Button mnemonicParsing="false" onAction="#confirmLogout" prefHeight="40.0" prefWidth="118.0" styleClass="logout-confirm-btn" text="Sign Out" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="20.0" top="10.0" />
                    </padding>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
