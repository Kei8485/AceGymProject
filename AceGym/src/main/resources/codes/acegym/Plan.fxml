<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="867.0" styleClass="main-content-bg" stylesheets="@../../Css/Plan.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.PlanController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
            </padding>
            <children>
                <Label styleClass="text-header" text="Plan" />

                <VBox prefWidth="807.0" spacing="20.0" styleClass="plan-form-card">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <children>
                        <HBox prefHeight="142.0" prefWidth="757.0" spacing="30.0">
                            <children>
                                <VBox prefHeight="74.0" prefWidth="477.0" spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="field-label" text="Plan Name" />
                                        <TextField prefHeight="39.0" prefWidth="477.0" styleClass="input-field" />
                                    </children>
                                </VBox>
                                <VBox prefWidth="250.0" spacing="8.0">
                                    <children>
                                        <Label styleClass="field-label" text="Validity" />
                                        <TextField prefHeight="39.0" prefWidth="250.0" styleClass="input-field" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <VBox maxWidth="500.0" prefHeight="143.0" prefWidth="500.0" spacing="8.0">
                            <children>
                                <Label styleClass="field-label" text="Amount" />
                                <TextField prefHeight="39.0" prefWidth="500.0" styleClass="input-field" />
                            </children>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" prefHeight="14.0" prefWidth="757.0" spacing="15.0">
                            <children>
                                <Button fx:id="addPlanBtn" mnemonicParsing="false" styleClass="btn-save" text="Add Plan" />
                                <Button mnemonicParsing="false" styleClass="btn-cancel" text="Edit" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox prefHeight="402.0" prefWidth="807.0" spacing="15.0" styleClass="card-bg" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="51.0" prefWidth="757.0" spacing="15.0">
                            <children>
                                <Label styleClass="text-header-smaller" text="Show Entities" />
                                <ComboBox prefWidth="80.0" styleClass="combo-box" />
                                <Region HBox.hgrow="ALWAYS" />
                                <StackPane alignment="CENTER_RIGHT">
                                    <children>
                                        <TextField prefHeight="27.0" prefWidth="253.0" promptText="Search" styleClass="search-field" />
                                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                                            <image><Image url="@../../image/magnifying-glass-solid.png" /></image>
                                            <StackPane.margin><Insets right="10.0" /></StackPane.margin>
                                        </ImageView>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>

                        <TableView fx:id="planTable" prefHeight="241.0" prefWidth="757.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn prefWidth="200.0" text="Plan Name" />
                                <TableColumn prefWidth="150.0" text="Validity" />
                                <TableColumn prefWidth="150.0" text="Amount" />
                                <TableColumn prefWidth="100.0" text="Edit" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
