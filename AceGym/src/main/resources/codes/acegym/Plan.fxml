<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefWidth="867.0" styleClass="main-content-bg" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.Controllers.PlanController">
    <stylesheets>
        <URL value="@../../Css/Plan.css" />
    </stylesheets>
    <children>
        <ScrollPane fitToWidth="true" styleClass="custom-scroll-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="20.0">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="24.0" />
                    </padding>
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <StackPane maxHeight="52" maxWidth="52" minHeight="52" minWidth="52" styleClass="header-icon-badge">
                                    <children>
                                        <ImageView fitHeight="32.0" fitWidth="38.0" pickOnBounds="true" preserveRatio="true">
                                            <image><Image url="@../../image/plan.png" /></image>
                                        </ImageView>
                                    </children>
                                </StackPane>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label styleClass="page-eyebrow" text="GYM CONFIGURATION" />
                                        <Label styleClass="page-title" text="Settings" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="14.0" styleClass="section-card">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <StackPane maxHeight="36" maxWidth="36" minHeight="36" minWidth="36" styleClass="section-icon-badge">
                                            <children>
                                                <ImageView fitHeight="26.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                                                    <image><Image url="@../../image/cash-app-brands-solid.png" /></image>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label styleClass="section-title" text="Payment Type" />
                                                <Label styleClass="section-subtitle" text="Add and manage membership plan types" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Region maxHeight="1.0" minHeight="1.0" styleClass="card-divider" />

                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="field-label" text="Plan Name" />
                                                <TextField fx:id="planNameField" prefHeight="38.0" promptText="e.g. Monthly, Annual..." styleClass="input-field" />
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="200.0" spacing="6.0">
                                            <children>
                                                <Label styleClass="field-label" text="Period (months)" />
                                                <TextField fx:id="planPeriodField" prefHeight="38.0" promptText="e.g. 1, 3, 12" styleClass="input-field" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox fx:id="planBtnRow" alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="addPlanBtn" prefHeight="36.0" styleClass="btn-primary" text="+ Add Plan" />
                                        <Button fx:id="cancelPlanBtn" managed="false" prefHeight="36.0" styleClass="btn-secondary" text="Cancel" visible="false" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label styleClass="toolbar-label" text="Plan Table" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="planSearchField" prefHeight="34.0" prefWidth="210.0" promptText="Search plans..." styleClass="search-field" />
                                                <ImageView fitHeight="14.0" fitWidth="14.0" mouseTransparent="true" pickOnBounds="true" preserveRatio="true">
                                                    <image><Image url="@../../image/magnifying-glass-solid.png" /></image>
                                                    <StackPane.margin><Insets right="11.0" /></StackPane.margin>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>

                                <TableView fx:id="planTable" prefHeight="200.0" styleClass="section-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="planNameCol" prefWidth="280.0" text="Plan Name" />
                                        <TableColumn fx:id="planPeriodCol" prefWidth="190.0" text="Period" />
                                        <TableColumn fx:id="planActionsCol" prefWidth="313.0" text="Actions" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox spacing="14.0" styleClass="section-card">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <StackPane maxHeight="36" maxWidth="36" minHeight="36" minWidth="36" styleClass="section-icon-badge">
                                            <children>
                                                <ImageView fitHeight="27.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true" rotate="58.4">
                                                    <image><Image url="@../../image/dumbbell-solid.png" /></image>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label styleClass="section-title" text="Training Category" />
                                                <Label styleClass="section-subtitle" text="Categorize training types and set pricing" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Region maxHeight="1.0" minHeight="1.0" styleClass="card-divider" />

                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="field-label" text="Category Name" />
                                                <TextField fx:id="categoryNameField" prefHeight="38.0" promptText="e.g. Lifting, Martial Arts..." styleClass="input-field" />
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="150.0" spacing="6.0">
                                            <children>
                                                <Label styleClass="field-label" text="Amount (PHP)" />
                                                <TextField fx:id="categoryAmountField" prefHeight="38.0" promptText="0.00" styleClass="input-field" />
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="150.0" spacing="6.0">
                                            <children>
                                                <Label styleClass="field-label" text="Coaching Fee (PHP)" />
                                                <TextField fx:id="categoryCoachingFeeField" prefHeight="38.0" promptText="0.00" styleClass="input-field" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox fx:id="categoryBtnRow" alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="addCategoryBtn" prefHeight="36.0" styleClass="btn-primary" text="+ Add Category" />
                                        <Button fx:id="cancelCategoryBtn" managed="false" prefHeight="36.0" styleClass="btn-secondary" text="Cancel" visible="false" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label styleClass="toolbar-label" text="Category Table" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="categorySearchField" prefHeight="34.0" prefWidth="210.0" promptText="Search categories..." styleClass="search-field" />
                                                <ImageView fitHeight="14.0" fitWidth="14.0" mouseTransparent="true" pickOnBounds="true" preserveRatio="true">
                                                    <image><Image url="@../../image/magnifying-glass-solid.png" /></image>
                                                    <StackPane.margin><Insets right="11.0" /></StackPane.margin>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>

                                <TableView fx:id="categoryTable" prefHeight="200.0" styleClass="section-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="categoryNameCol" prefWidth="250.0" text="Category Name" />
                                        <TableColumn fx:id="categoryAmountCol" prefWidth="140.0" text="Amount" />
                                        <TableColumn fx:id="categoryCoachingFeeCol" prefWidth="140.0" text="Coaching Fee" />
                                        <TableColumn fx:id="categoryActionsCol" prefWidth="100.0" text="Actions" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox spacing="14.0" styleClass="section-card">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <StackPane maxHeight="36" maxWidth="36" minHeight="36" minWidth="36" styleClass="section-icon-badge">
                                            <children>
                                                <ImageView fitHeight="57.0" fitWidth="52.0" pickOnBounds="true" preserveRatio="true">
                                                    <image><Image url="@../../image/etoNa.png" /></image>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label styleClass="section-title" text="Client Discount" />
                                                <Label styleClass="section-subtitle" text="Set discount rates for Member and Non-Member clients" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Region maxHeight="1.0" minHeight="1.0" styleClass="card-divider" />

                                <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="info-banner">
                                    <padding>
                                        <Insets bottom="10.0" left="12.0" right="12.0" top="10.0" />
                                    </padding>
                                    <children>
                                        <Label styleClass="info-banner-icon" text="i" />
                                        <Label styleClass="info-banner-text" text="Only the discount percentage can be changed. Client types (Member, Non-Member) are fixed." />
                                    </children>
                                </HBox>

                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="field-label" text="Client Type" />
                                                <ComboBox fx:id="clientTypeCombo" maxWidth="Infinity" prefHeight="38.0" promptText="Select client type" styleClass="input-combo" />
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="200.0" spacing="6.0">
                                            <children>
                                                <Label styleClass="field-label" text="Discount (%)" />
                                                <TextField fx:id="discountField" prefHeight="38.0" promptText="e.g. 30" styleClass="input-field" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="saveDiscountBtn" prefHeight="36.0" styleClass="btn-primary" text="Save Changes" />
                                        <Button fx:id="cancelDiscountBtn" prefHeight="36.0" styleClass="btn-secondary" text="Cancel" />
                                    </children>
                                </HBox>

                                <TableView fx:id="discountTable" prefHeight="150.0" styleClass="section-table">
                                    <columns>
                                        <TableColumn fx:id="clientTypeCol" prefWidth="300.0" text="Client Type" />
                                        <TableColumn fx:id="discountCol" prefWidth="160.0" text="Discount" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
