<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="800.0" prefWidth="900.0" styleClass="main-content-bg" stylesheets="@../../Css/Registration.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.RegistrationController">
    <children>
        <ScrollPane fitToWidth="true" styleClass="custom-scroll-pane" stylesheets="@../../Css/Registration.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="30.0">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>
                        <VBox spacing="15.0">
                            <children>
                                <Label styleClass="text-header" text="Client Registration" />
                                <VBox spacing="20.0" styleClass="card-content-area">
                                    <children>
                                        <GridPane hgap="20.0" vgap="15.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                                            </rowConstraints>
                                            <children>
                                                <Label styleClass="text-header-smaller" text="First Name" />
                                                <Label styleClass="text-header-smaller" text="Last Name" GridPane.columnIndex="1" />
                                                <Label styleClass="text-header-smaller" text="Date of Registration" GridPane.columnIndex="2" />
                                                <TextField styleClass="date-field" GridPane.rowIndex="1" />
                                                <TextField styleClass="date-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                <TextField promptText="MM/DD/YYYY" styleClass="date-field" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                                <Label styleClass="text-header-smaller" text="Email Address" GridPane.rowIndex="2" />
                                                <Label styleClass="text-header-smaller" text="Contact No." GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                                <TextField styleClass="date-field" GridPane.columnSpan="2" GridPane.rowIndex="3" />
                                                <TextField styleClass="date-field" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                            </children>
                                        </GridPane>
                                        <HBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Button mnemonicParsing="false" styleClass="btn-manage" text="Register" />
                                            </children>
                                        </HBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                                    </padding>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="15.0">
                            <children>
                                <Label styleClass="text-header" text="Membership Registration" />
                                <VBox spacing="20.0" styleClass="card-content-area">
                                    <children>
                                        <HBox spacing="15.0">
                                            <children>
                                                <ComboBox fx:id="clientSearchBox" editable="true" prefWidth="250.0" promptText="Search Client" styleClass="combo-box" visibleRowCount="7" />
                                                <ComboBox prefHeight="34.0" prefWidth="105.0" promptText="Filter" styleClass="combo-box" visibleRowCount="7" />
                                            </children>
                                        </HBox>
                                        <GridPane hgap="20.0" vgap="15.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                                            </rowConstraints>
                                            <children>
                                                <Label styleClass="text-header-smaller" text="First Name" />
                                                <Label styleClass="text-header-smaller" text="Last Name" GridPane.columnIndex="1" />
                                                <Label styleClass="text-header-smaller" text="Date of Registration" GridPane.columnIndex="2" />
                                                <TextField editable="false" styleClass="date-field" GridPane.rowIndex="1" />
                                                <TextField editable="false" styleClass="date-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                <TextField editable="false" styleClass="date-field" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                                <Label styleClass="text-header-smaller" text="Email Address" GridPane.rowIndex="2" />
                                                <Label styleClass="text-header-smaller" text="Contact No." GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                <TextField editable="false" styleClass="date-field" GridPane.columnSpan="2" GridPane.rowIndex="3" />
                                                <TextField editable="false" styleClass="date-field" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                            </children>
                                        </GridPane>
                                        <HBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Button mnemonicParsing="false" styleClass="btn-manage" text="Avail Membership" />
                                            </children>
                                        </HBox>
                                    </children>
                                    <padding>
                                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                                    </padding>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
