<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="260.0" prefWidth="340.0" styleClass="card-container" stylesheets="@../../Css/CoachCard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.Controllers.CoachCardController">
    <children>

        <VBox spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- ── HEADER: Avatar + Name/ID/Badge + X ── -->
                <HBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="337.0" spacing="14.0" styleClass="card-header">
                    <children>

                        <StackPane maxHeight="68.0" maxWidth="60.0" minHeight="56.0" minWidth="56.0" prefHeight="68.0" prefWidth="60.0" styleClass="avatar-frame">
                            <children>
                                <ImageView fx:id="coachImage" fitHeight="73.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../../image/admin-user.png" />
                                    </image>
                                </ImageView>
                            </children>
                        </StackPane>

                        <VBox alignment="CENTER_LEFT" spacing="4.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="nameLabel" maxWidth="Infinity" styleClass="coach-name" text="Coach Name" wrapText="true" />
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label fx:id="idLabel" prefHeight="20.0" prefWidth="79.0" styleClass="coach-id" text="ST000" />
                                        <Label fx:id="trainingTypeLabel" prefHeight="23.0" prefWidth="142.0" styleClass="training-type-badge" text="No Training Type" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- X remove button -->
                        <StackPane alignment="CENTER" maxHeight="38.0" maxWidth="26.0" minHeight="26.0" minWidth="26.0" prefWidth="40.0" styleClass="remove-btn-bg">
                            <children>
                                <ImageView fx:id="removeCoachBtn" fitHeight="29.0" fitWidth="31.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../../image/xmark-solid.png" />
                                    </image>
                                </ImageView>
                            </children>
                        </StackPane>

                    </children>
                    <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0" /></padding>
                </HBox>

                <!-- ── DIVIDER ── -->
                <Region maxWidth="Infinity" styleClass="card-divider" />

                <!-- ── CLIENTS SECTION ── -->
                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="6.0">
                            <children>
                                <Region maxHeight="6.0" maxWidth="6.0" minHeight="6.0" minWidth="6.0" styleClass="section-dot" />
                                <Label styleClass="section-title" text="CLIENTS HANDLING" />
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="72.0" prefHeight="72.0" styleClass="clients-scroll" vbarPolicy="AS_NEEDED">
                            <content>
                                <VBox fx:id="clientsContainer" spacing="4.0" />
                            </content>
                        </ScrollPane>

                    </children>
                    <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0" /></padding>
                </VBox>

                <!-- ── DIVIDER ── -->
                <Region maxWidth="Infinity" styleClass="card-divider" />

                <!-- ── BUTTONS ── -->
                <HBox spacing="8.0">
                    <children>
                        <Button fx:id="editCoachBtn" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-edit" text="Edit Coach" HBox.hgrow="ALWAYS" />
                        <Button fx:id="manageClientBtn" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-manage" text="Manage Clients" HBox.hgrow="ALWAYS" />
                    </children>
                    <padding><Insets bottom="12.0" left="16.0" right="16.0" top="12.0" /></padding>
                </HBox>

            </children>
        </VBox>

    </children>
</AnchorPane>
