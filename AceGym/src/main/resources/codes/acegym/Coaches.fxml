<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #0E1223;" stylesheets="@../../Css/Coaches.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.CoachesController">
    <children>
        <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox spacing="10.0">
                    <children>
                        <Label styleClass="text-header" text="Coaches" />
                        <Button fx:id="addCoachBtn" mnemonicParsing="false" styleClass="btn-add-coach" text="Add Coach" />
                    </children>
                </VBox>

                <VBox styleClass="card-content-area" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" styleClass="header-row">
                            <children>
                                <Label prefHeight="23.0" prefWidth="295.0" styleClass="label-search" text="Manage Coaches" HBox.hgrow="ALWAYS">
                           <padding>
                              <Insets left="10.0" />
                           </padding>
                           <HBox.margin>
                              <Insets left="10.0" />
                           </HBox.margin></Label>
                                <Region prefHeight="28.0" prefWidth="259.0" HBox.hgrow="ALWAYS" /> <HBox alignment="CENTER" spacing="5.0">
                                <children>
                                    <TextField promptText="Search" styleClass="search-field" />
                                    <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true" styleClass="search-icon">
                                        <image>
                                            <Image url="@../../image/magnifying-glass-solid.png" /> </image>
                                    </ImageView>
                                </children>
                           <HBox.margin>
                              <Insets right="10.0" />
                           </HBox.margin>
                            </HBox>
                            </children>
                     <VBox.margin>
                        <Insets left="20.0" right="20.0" />
                     </VBox.margin>
                        </HBox>

                        <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS">
                            <content>
                                <TilePane fx:id="coachContainer" hgap="30.0" vgap="30.0">
                                    <padding>
                                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                                    </padding>
                                </TilePane>
                            </content>
                        </ScrollPane>
                    </children>
                    <padding>
                        <Insets top="30.0" />
                    </padding>
                </VBox>
            </children>
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
