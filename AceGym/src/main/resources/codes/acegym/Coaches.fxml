<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #0E1223;"
            stylesheets="@../../Css/Coaches.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="codes.acegym.Controllers.CoachesController">
    <children>
        <VBox spacing="20.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <padding><Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/></padding>
            <children>

                <!-- ══ PAGE HEADER ══════════════════════════════════════ -->
                <HBox alignment="CENTER_LEFT" spacing="16.0">
                    <children>

                        <!-- Icon box -->
                        <StackPane styleClass="header-icon-box">
                            <children>
                                <ImageView fitHeight="28.0" fitWidth="28.0"
                                           pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../../image/arrows-down-to-people-solid.png"/>
                                    </image>
                                </ImageView>
                            </children>
                        </StackPane>

                        <!-- Title block -->
                        <VBox spacing="0.0">
                            <children>
                                <Label styleClass="pos-header" text="SESSION ASSIGNMENTS"/>
                                <Label styleClass="text-header" text="Coaches">
                                    <padding><Insets top="-6.0"/></padding>
                                </Label>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- Add Coach button — top right -->
                        <Button fx:id="addCoachBtn"
                                mnemonicParsing="false"
                                styleClass="btn-add-coach"
                                text="+ Add Coach"/>
                    </children>
                </HBox>

                <!-- ══ CARD CONTENT AREA ════════════════════════════════ -->
                <VBox styleClass="card-content-area" VBox.vgrow="ALWAYS" spacing="0.0">
                    <children>

                        <!-- ── Toolbar: title + filter + search ── -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="toolbar-row">
                            <padding><Insets top="18.0" right="20.0" bottom="18.0" left="20.0"/></padding>
                            <children>

                                <Label styleClass="label-manage" text="Manage Coaches"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <!-- Filter combo -->
                                <ComboBox fx:id="filterCombo"
                                          prefHeight="40.0" prefWidth="155.0"
                                          promptText="All"
                                          styleClass="custom-combo-box"/>

                                <!-- Search wrapper: icon inside StackPane + TextField -->
                                <HBox styleClass="search-wrapper" alignment="CENTER_LEFT" spacing="8.0">
                                    <padding><Insets left="12.0" right="12.0"/></padding>
                                    <children>
                                        <StackPane alignment="CENTER"
                                                   minWidth="16.0" maxWidth="16.0"
                                                   minHeight="16.0" maxHeight="16.0">
                                            <children>
                                                <ImageView fitHeight="16.0" fitWidth="16.0"
                                                           pickOnBounds="true" preserveRatio="true"
                                                           styleClass="search-icon">
                                                    <image>
                                                        <Image url="@../../image/magnifying-glass-solid.png"/>
                                                    </image>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                        <TextField fx:id="searchField"
                                                   promptText="Search coaches..."
                                                   styleClass="search-field"
                                                   prefHeight="40.0"
                                                   prefWidth="210.0"/>
                                    </children>
                                </HBox>

                            </children>
                        </HBox>

                        <!-- Divider under toolbar -->
                        <Region styleClass="toolbar-divider" maxWidth="Infinity"/>

                        <!-- ── Coach cards grid ── -->
                        <ScrollPane fx:id="scrollPane"
                                    fitToWidth="true"
                                    styleClass="custom-scroll-pane"
                                    VBox.vgrow="ALWAYS">
                            <content>
                                <TilePane fx:id="coachContainer"
                                          alignment="TOP_LEFT"
                                          hgap="20.0" vgap="20.0">
                                    <padding>
                                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                                    </padding>
                                    <styleClass>
                                        <String fx:value="tile-pane"/>
                                    </styleClass>
                                </TilePane>
                            </content>
                            <padding><Insets right="4.0"/></padding>
                        </ScrollPane>

                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
