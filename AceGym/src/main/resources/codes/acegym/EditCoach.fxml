<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="560.0" prefWidth="500.0"
            styleClass="main-content-bg"
            stylesheets="@../../Css/EditCoach.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="codes.acegym.Controllers.EditCoachController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="22.0" styleClass="profile-card"
              AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="50.0"
              AnchorPane.rightAnchor="50.0"  AnchorPane.topAnchor="50.0">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="20.0" />
            </padding>
            <children>

                <!-- ── Profile image + header area ── -->
                <StackPane alignment="TOP_CENTER">
                    <children>
                        <!-- Dark header band -->
                        <VBox alignment="CENTER" prefHeight="120.0" styleClass="header-content-area">
                            <padding>
                                <Insets bottom="15.0" left="20.0" right="20.0" top="55.0" />
                            </padding>
                            <children>
                                <Label styleClass="section-header" text="Edit Coach Profile" />
                            </children>
                            <StackPane.margin><Insets top="80.0" /></StackPane.margin>
                        </VBox>

                        <!-- Circular image — clicking opens file chooser -->
                        <StackPane alignment="CENTER" maxHeight="110.0" maxWidth="110.0">
                            <children>
                                <ImageView fx:id="coachImageView"
                                           fitHeight="110.0" fitWidth="110.0"
                                           onMouseClicked="#handleChangeProfile"
                                           pickOnBounds="true" preserveRatio="true"
                                           styleClass="clickable-profile">
                                    <image><Image url="@../../image/admin-user.png" /></image>
                                    <StackPane.margin><Insets bottom="10.0" /></StackPane.margin>
                                </ImageView>
                                <Label mouseTransparent="true"
                                       styleClass="camera-icon-overlay"
                                       text="📷"
                                       StackPane.alignment="BOTTOM_RIGHT">
                                    <StackPane.margin><Insets bottom="5.0" right="5.0" /></StackPane.margin>
                                </Label>
                            </children>
                        </StackPane>
                    </children>
                </StackPane>

                <!-- ── Section title ── -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label styleClass="icon-edit" text="📝" />
                        <Label styleClass="section-header" text="Update Profile" />
                    </children>
                </HBox>

                <!-- ── First Name ── -->
                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="input-label" text="First Name" />
                        <TextField fx:id="editFirstName"
                                   promptText="First Name"
                                   styleClass="underlined-input" />
                    </children>
                </VBox>

                <!-- ── Last Name ── -->
                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="input-label" text="Last Name" />
                        <TextField fx:id="editLastName"
                                   promptText="Last Name"
                                   styleClass="underlined-input" />
                    </children>
                </VBox>

                <!-- ── Training Type (dropdown) ── -->
                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="input-label" text="Training Type" />
                        <ComboBox fx:id="editTrainingType"
                                  maxWidth="Infinity"
                                  promptText="Select Training Type"
                                  styleClass="underlined-input" />
                    </children>
                </VBox>

                <!-- ── Error label ── -->
                <Label fx:id="errorLabel"
                       style="-fx-text-fill: #e53935; -fx-font-size: 12px;"
                       text=""
                       visible="false"
                       managed="false"
                       wrapText="true" />

                <!-- ── Buttons ── -->
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnSave"   onAction="#handleSave"   styleClass="btn-red"   text="Save" />
                        <Button fx:id="btnCancel" onAction="#handleCancel" styleClass="btn-white" text="Cancel" />
                    </children>
                    <padding><Insets top="10.0" /></padding>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
