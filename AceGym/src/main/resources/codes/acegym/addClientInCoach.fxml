<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="500.0"
            styleClass="main-content-bg"
            stylesheets="@../../Css/AddClientInCoach.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="codes.acegym.Controllers.AddClientInCoachController">
    <children>
        <StackPane fx:id="contentStack" styleClass="main-container"
                   AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0"
                   AnchorPane.rightAnchor="20.0"  AnchorPane.topAnchor="20.0">
            <children>

                <!-- ══════════════════════════════════════════════════════
                     MAIN LIST VIEW — shows assigned clients
                ══════════════════════════════════════════════════════ -->
                <VBox fx:id="mainListView" spacing="20.0">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <children>

                        <!-- Dynamic coach name header -->
                        <Label fx:id="headerLabel"
                               styleClass="header-text"
                               text="Manage Clients for Coach" />

                        <!-- Add client button -->
                        <VBox spacing="10.0">
                            <Label styleClass="sub-header" text="Assigned Clients" />
                            <Button onAction="#handleSwitchToSelection"
                                    styleClass="plus-button"
                                    text="+ Add Client"
                                    maxWidth="Infinity" />
                        </VBox>

                        <!-- Scrollable list of assigned clients -->
                        <ScrollPane fitToWidth="true"
                                    styleClass="custom-scroll-pane"
                                    VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="clientListContainer" spacing="12.0">
                                    <padding><Insets bottom="8.0" right="4.0" /></padding>
                                </VBox>
                            </content>
                        </ScrollPane>

                        <!-- Bottom buttons -->
                        <HBox alignment="CENTER" spacing="15.0">
                            <Button onAction="#handleCancel"
                                    styleClass="cancel-button"
                                    text="Close" />
                        </HBox>

                    </children>
                </VBox>

                <!-- ══════════════════════════════════════════════════════
                     ADD CLIENT VIEW — ComboBox dropdown, auto-filled info
                ══════════════════════════════════════════════════════ -->
                <VBox fx:id="clientDetailsView" spacing="20.0" visible="false">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <children>

                        <!-- Step header -->
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <Label styleClass="step-number" text="1" />
                            <Label styleClass="sub-header" text="Select Client" />
                        </HBox>

                        <!-- Client dropdown — populated from DB (unassigned only) -->
                        <VBox spacing="10.0">
                            <Label styleClass="header-text" text="Choose a Client" />
                            <!-- ComboBox styled inline to match dark theme -->
                            <ComboBox fx:id="clientComboBox"
                                      maxWidth="Infinity"
                                      promptText="Select a client..."
                                      style="-fx-background-color: #1c2237;
                                             -fx-border-color: #2e3349;
                                             -fx-border-radius: 8;
                                             -fx-border-width: 1.5;
                                             -fx-text-fill: #e8e8f0;
                                             -fx-font-size: 13px;
                                             -fx-padding: 6 10 6 10;" />
                        </VBox>

                        <!-- Client details — auto-filled on selection -->
                        <VBox spacing="15.0" styleClass="details-card">
                            <children>
                                <Label styleClass="details-header" text="CLIENT DETAILS" />
                                <GridPane hgap="10.0" vgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="110.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints />
                                    </rowConstraints>
                                    <children>
                                        <Label styleClass="field-label" text="Client ID:"
                                               GridPane.rowIndex="0" />
                                        <TextField fx:id="displayClientId"
                                                   editable="false"
                                                   styleClass="display-field"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label styleClass="field-label" text="Full Name:"
                                               GridPane.rowIndex="1" />
                                        <TextField fx:id="displayFullName"
                                                   editable="false"
                                                   styleClass="display-field"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label styleClass="field-label" text="Client Type:"
                                               GridPane.rowIndex="2" />
                                        <TextField fx:id="displayClientType"
                                                   editable="false"
                                                   styleClass="display-field"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label styleClass="field-label" text="Contact:"
                                               GridPane.rowIndex="3" />
                                        <TextField fx:id="displayContact"
                                                   editable="false"
                                                   styleClass="display-field"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <!-- Error label -->
                        <Label fx:id="errorLabel"
                               style="-fx-text-fill: #e53935; -fx-font-size: 12px;"
                               text=""
                               visible="false"
                               managed="false"
                               wrapText="true" />

                        <!-- Action buttons -->
                        <HBox alignment="CENTER" spacing="15.0">
                            <Button onAction="#handleBackToMain"
                                    styleClass="cancel-button"
                                    text="Back"
                                    HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleConfirmAddClient"
                                    styleClass="confirm-button"
                                    text="Add Client"
                                    HBox.hgrow="ALWAYS" />
                        </HBox>

                    </children>
                </VBox>

            </children>
        </StackPane>
    </children>
</AnchorPane>
