<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="1080.0" prefWidth="1920.0" styleClass="main-bg" stylesheets="@../../Css/styles2.css, @../../Css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.HomePageController">

    <children>
        <HBox maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="738.0" prefWidth="1177.0" style="-fx-background-color: transparent; -fx-border-width: 2; -fx-border-radius: 25;">

            <children>
                <VBox prefHeight="738.0" prefWidth="259.0" spacing="75.0" style="-fx-background-color: #192037; -fx-background-radius: 25 0 0 25;">

                    <children>
                        <Label prefHeight="126.0" prefWidth="185.0" text="Ace Fitness Gym" textFill="#ee4f5c" wrapText="true">

                            <font>
                                <Font size="29.0" />
                            </font>
                     <padding>
                        <Insets left="15.0" top="15.0" />
                     </padding>
                        </Label>

                        <VBox alignment="CENTER_RIGHT" prefHeight="343.0" prefWidth="259.0" spacing="4.0">

                            <children>
                                <ToggleButton fx:id="dashboardBtn" alignment="CENTER_LEFT" graphicTextGap="10" maxHeight="53.0" minHeight="32.0" prefHeight="45.0" prefWidth="207.0" selected="true" styleClass="menu-button" text="Dashboard" toggleGroup="$menuGroup">

                                    <graphic>
                                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                            <Image url="@../../image/dashboard.png" />
                                        </ImageView>
                                    </graphic>


                                </ToggleButton>

                                <ToggleButton fx:id="adminProfile" alignment="CENTER_LEFT" graphicTextGap="10" maxHeight="55.0" minHeight="32.0" prefHeight="45.0" prefWidth="207.0" styleClass="menu-button" text="Admin Profile" toggleGroup="$menuGroup">

                                    <graphic>
                                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                            <Image url="@../../image/admin-profile.png" />
                                        </ImageView>
                                    </graphic>
                                </ToggleButton>

                                <ToggleButton fx:id="registrationForm" alignment="CENTER_LEFT" graphicTextGap="10" maxHeight="55.0" minHeight="32.0" prefHeight="45.0" prefWidth="207.0" styleClass="menu-button" text="Registration" toggleGroup="$menuGroup">

                                    <graphic>
                                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                            <Image url="@../../image/registration.png" />
                                        </ImageView>
                                    </graphic>
                                </ToggleButton>

                                <ToggleButton fx:id="planForm" alignment="CENTER_LEFT" graphicTextGap="10" maxHeight="55.0" minHeight="32.0" prefHeight="45.0" prefWidth="207.0" styleClass="menu-button" text="Plan" toggleGroup="$menuGroup">

                                    <graphic>
                                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                            <Image url="@../../image/plan.png" />
                                        </ImageView>
                                    </graphic>
                                </ToggleButton>

                                <ToggleButton fx:id="PaymentForm" alignment="CENTER_LEFT" graphicTextGap="10" maxHeight="55.0" minHeight="32.0" prefHeight="45.0" prefWidth="207.0" styleClass="menu-button" text="Payment" toggleGroup="$menuGroup">

                                    <graphic>
                                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                            <Image url="@../../image/payment.png" />
                                        </ImageView>
                                    </graphic>
                                </ToggleButton>

                                <ToggleButton fx:id="MembersForm" alignment="CENTER_LEFT" graphicTextGap="10" maxHeight="55.0" minHeight="32.0" prefHeight="45.0" prefWidth="207.0" styleClass="menu-button" text="View Members" toggleGroup="$menuGroup">

                                    <graphic>
                                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                            <Image url="@../../image/members.png" />
                                        </ImageView>
                                    </graphic>
                                </ToggleButton>

                                <ToggleButton fx:id="CoachList" alignment="CENTER_LEFT" graphicTextGap="10" maxHeight="55.0" minHeight="32.0" prefHeight="45.0" prefWidth="207.0" styleClass="menu-button" text="Coaches" toggleGroup="$menuGroup">

                                    <graphic>
                                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                            <Image url="@../../image/coaches.png" />
                                        </ImageView>
                                    </graphic>
                                </ToggleButton>

                                <ToggleButton fx:id="ReportForm" alignment="CENTER_LEFT" graphicTextGap="10" maxHeight="55.0" minHeight="32.0" prefHeight="45.0" prefWidth="207.0" styleClass="menu-button" text="Report" toggleGroup="$menuGroup">

                                    <graphic>
                                        <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true">
                                            <Image url="@../../image/report.png" />
                                        </ImageView>
                                    </graphic>
                                </ToggleButton>

                            </children>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefHeight="194.0" prefWidth="259.0" spacing="35.0" style="-fx-padding: 0;">

                            <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="143.0" spacing="10">
                                <ImageView fitHeight="40" fitWidth="40">
                                    <Image url="@../../image/User.png" />
                                </ImageView>

                                <VBox>
                                    <Label style="-fx-text-fill: white; -fx-font-size: 14px;" text="Peter Parker" />
                                    <Label style="-fx-text-fill: #9aa4bf; -fx-font-size: 11px;" text="Admin" />
                           <HBox.margin>
                              <Insets />
                           </HBox.margin>
                                </VBox>
                        <VBox.margin>
                           <Insets />
                        </VBox.margin>
                        <opaqueInsets>
                           <Insets />
                        </opaqueInsets>
                        <padding>
                           <Insets left="15.0" />
                        </padding>
                            </HBox>

                            <HBox alignment="CENTER_RIGHT">
                                <Button alignment="CENTER_LEFT" graphicTextGap="6" prefHeight="28.0" prefWidth="91.0" style="-fx-background-color: #DE6161; -fx-text-fill: black; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 12 0 0 12;-fx-border-radius: 12 0 0 12; -fx-padding: 4 8;" text="Logout">

                                    <graphic>
                                        <ImageView fitHeight="12.0" fitWidth="12.0" preserveRatio="true">
                                            <Image url="@../../image/exit.png" />
                                        </ImageView>
                                    </graphic>

                                </Button>
                            </HBox>
                        </VBox>
                    </children>
                </VBox>

                <VBox prefHeight="738.0" prefWidth="888.0" style="-fx-background-color: #0E1223; -fx-background-radius: 0 25 25 0;" />
            </children>
        </HBox>
    </children>
</StackPane>
