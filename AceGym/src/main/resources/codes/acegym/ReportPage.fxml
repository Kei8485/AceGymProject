<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="reportRoot" maxHeight="-1.0" maxWidth="867.0" minHeight="650.0" minWidth="867.0" prefHeight="650.0" prefWidth="867.0" styleClass="main-content-bg" stylesheets="@../../Css/ReportPage.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.ReportPageController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label prefHeight="60.0" styleClass="text-header" text="Sales Report" textFill="#e8e6e9">
                    <padding>
                        <Insets left="30.0" top="10.0" />
                    </padding>
                </Label>

                <AnchorPane minHeight="120.0" prefWidth="810.0" styleClass="card-search">
                    <children>
                        <HBox alignment="CENTER_LEFT" layoutX="90.0" layoutY="20.0" spacing="30.0" AnchorPane.leftAnchor="90.0" AnchorPane.rightAnchor="90.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="text-header-small" text="From Date" textFill="#e8e6e9" />
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField prefHeight="35.0" styleClass="date-field" />
                                                <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                                    <image><Image url="@../../image/calendar-check-regular.png" /></image>
                                                    <StackPane.margin><Insets right="10.0" /></StackPane.margin>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="text-header-small" text="To Date" textFill="#e8e6e9" />
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField prefHeight="35.0" styleClass="date-field" />
                                                <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                                    <image><Image url="@../../image/calendar-check-regular.png" /></image>
                                                    <StackPane.margin><Insets right="10.0" /></StackPane.margin>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                    <VBox.margin>
                        <Insets left="20.0" right="20.0" />
                    </VBox.margin>
                </AnchorPane>

                <AnchorPane styleClass="card-search" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets bottom="15.0" left="20.0" right="20.0" />
                    </VBox.margin>
                    <children>
                        <VBox spacing="10.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="15.0">
                            <children>
                                <Label styleClass="text-header-small" text="Payment History" textFill="#e8e6e9" />
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label styleClass="text-header-smaller" text="Show" textFill="#cdcdcd" />
                                        <ComboBox prefHeight="29.0" prefWidth="95.0" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <TextField prefWidth="200.0" promptText="Search" styleClass="search-field" />
                                        <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                            <image><Image url="@../../image/magnifying-glass-solid.png" /></image>
                                        </ImageView>
                                    </children>
                                </HBox>
                                <TableView VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn prefWidth="109.0" text="ClientId" />
                                        <TableColumn prefWidth="97.0" text="First Name" />
                                        <TableColumn prefWidth="385.0" text="Last Name" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
