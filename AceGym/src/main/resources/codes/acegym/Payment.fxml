<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane maxHeight="1.7976931348623157E308" prefWidth="867.0" styleClass="payment-page-bg" stylesheets="@../../Css/Payment.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.Controllers.PaymentController">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="custom-scroll-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="25.0" styleClass="main-container">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="25.0" />
                    </padding>
                    <children>

                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="page-header-box">
                            <children>
                                <VBox alignment="CENTER" styleClass="header-icon-box">
                           <children>
                              <ImageView fitHeight="41.0" fitWidth="42.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../../image/cart-shopping-solid.png" />
                                 </image>
                              </ImageView>
                           </children>
                                </VBox>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label styleClass="pos-header" text="Point of Sale" />
                                        <Label styleClass="add-payment-header" text="Add Payment" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- Body -->
                        <HBox spacing="20.0">
                            <children>

                                <!-- LEFT COLUMN: Steps -->
                                <VBox spacing="16.0" styleClass="steps-column" HBox.hgrow="ALWAYS">
                                    <children>

                                        <!-- Step 1: Identify Client -->
                                        <VBox spacing="14.0" styleClass="payment-card-step">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                    <children>
                                                        <Label styleClass="step-number" text="1" />
                                                        <Label styleClass="step-title" text="Identify Client" />
                                                    </children>
                                                </HBox>
                                                <Label styleClass="step-sub-label" text="Search Client Name or ID" />
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="search-field-wrapper" HBox.hgrow="ALWAYS">
                                                            <padding>
                                                                <Insets left="12.0" right="12.0" />
                                                            </padding>
                                                            <children>
                                                                <Label styleClass="search-icon" text="🔍" />
                                                                <ComboBox fx:id="clientSearchCombo" editable="true" maxWidth="Infinity" promptText="Enter name or client ID..." styleClass="search-combo" HBox.hgrow="ALWAYS" />
                                                            </children>
                                                        </HBox>
                                                        <Button prefHeight="42.0" prefWidth="100.0" styleClass="btn-search-red" text="Search" />
                                                    </children>
                                                </HBox>

                                                <!-- Client Details Box -->
                                                <VBox spacing="10.0" styleClass="client-details-box">
                                                    <padding>
                                                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                                                    </padding>
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                                            <children>
                                                                <Label styleClass="details-icon" text="👤" />
                                                                <Label styleClass="details-header" text="CLIENT DETAILS" />
                                                            </children>
                                                        </HBox>
                                                        <GridPane hgap="10.0" vgap="8.0">
                                                            <columnConstraints>
                                                                <ColumnConstraints prefWidth="110.0" />
                                                                <ColumnConstraints hgrow="ALWAYS" />
                                                            </columnConstraints>
                                                            <rowConstraints>
                                                                <RowConstraints minHeight="32.0" />
                                                                <RowConstraints minHeight="32.0" />
                                                                <RowConstraints minHeight="32.0" />
                                                                <RowConstraints minHeight="32.0" />
                                                            </rowConstraints>
                                                            <children>
                                                                <Label styleClass="detail-label" text="Client ID:" GridPane.rowIndex="0" />
                                                                <TextField fx:id="clientIdDisplay" editable="false" styleClass="input-display" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                                                <Label styleClass="detail-label" text="Full Name:" GridPane.rowIndex="1" />
                                                                <TextField fx:id="clientNameDisplay" editable="false" styleClass="input-display" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                                                <Label styleClass="detail-label" text="Email:" GridPane.rowIndex="2" />
                                                                <TextField fx:id="clientEmailDisplay" editable="false" styleClass="input-display" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                                                <Label styleClass="detail-label" text="Client Type:" GridPane.rowIndex="3" />
                                                                <Label fx:id="clientTypeTag" styleClass="type-tag-member" text="Member" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                                            </children>
                                                        </GridPane>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <!-- Step 2: Configure Training -->
                                        <VBox spacing="12.0" styleClass="payment-card-step">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                    <children>
                                                        <Label styleClass="step-number" text="2" />
                                                        <Label styleClass="step-title" text="Configure Training" />
                                                    </children>
                                                </HBox>
                                                <Label styleClass="step-sub-label" text="Payment Period" />
                                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="combo-wrapper">
                                                    <padding>
                                                        <Insets left="12.0" right="12.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="combo-icon" text="📅" />
                                                        <ComboBox fx:id="periodCombo" maxWidth="Infinity" promptText="Select Payment Period" styleClass="combo-field" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                                <Label styleClass="step-sub-label" text="Training Type" />
                                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="combo-wrapper">
                                                    <padding>
                                                        <Insets left="12.0" right="12.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="combo-icon" text="🏋" />
                                                        <ComboBox fx:id="typeCombo" maxWidth="Infinity" promptText="Select Training Type" styleClass="combo-field" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <!-- Step 3: Select Payment Method -->
                                        <VBox spacing="12.0" styleClass="payment-card-step">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                    <children>
                                                        <Label styleClass="step-number" text="3" />
                                                        <Label styleClass="step-title" text="Select Payment Method" />
                                                    </children>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="combo-wrapper">
                                                    <padding>
                                                        <Insets left="12.0" right="12.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="combo-icon" text="💳" />
                                                        <ComboBox fx:id="methodCombo" maxWidth="Infinity" promptText="Select Payment Method" styleClass="combo-field" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                    </children>
                                </VBox>

                                <!-- RIGHT COLUMN: Financial Summary -->
                                <VBox prefWidth="300.0" spacing="0.0" styleClass="summary-card">
                                    <padding>
                                        <Insets bottom="25.0" left="22.0" right="22.0" top="25.0" />
                                    </padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label styleClass="summary-icon" text="📋" />
                                                <Label styleClass="summary-header" text="Financial Summary" />
                                            </children>
                                        </HBox>

                                        <VBox spacing="14.0">
                                            <VBox.margin>
                                                <Insets top="28.0" />
                                            </VBox.margin>
                                            <children>
                                                <!-- Price Row -->
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label maxWidth="Infinity" styleClass="summary-label" text="Price of Training" HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="priceLabel" styleClass="summary-value-box" text="₱0.00" />
                                                    </children>
                                                </HBox>

                                                <!-- Discount Row -->
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label maxWidth="Infinity" styleClass="summary-label" text="Discount" HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="discountLabel" styleClass="summary-value-red" text="- ₱0.00" />
                                                    </children>
                                                </HBox>

                                                <!-- Subtotal Row -->
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label maxWidth="Infinity" styleClass="summary-label" text="Subtotal" HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="subtotalLabel" styleClass="summary-value-box" text="₱0.00" />
                                                    </children>
                                                </HBox>

                                                <Separator styleClass="summary-divider" />

                                                <!-- Total Box -->
                                                <VBox alignment="CENTER" spacing="8.0" styleClass="total-box">
                                                    <padding>
                                                        <Insets bottom="20.0" top="20.0" />
                                                    </padding>
                                                    <children>
                                                        <Label styleClass="total-label" text="TOTAL PRICE" />
                                                        <Label fx:id="totalPriceLabel" styleClass="total-amount" text="₱0.00" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <!-- Action Buttons -->
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button fx:id="ClearBtn" mnemonicParsing="false" prefHeight="45.0" prefWidth="120.0" styleClass="btn-cancel-dark" text="✕  Cancel" />
                                <Button fx:id="AddPaymentBtn" mnemonicParsing="false" prefHeight="45.0" prefWidth="180.0" styleClass="btn-save-red" text="💾  Save Payment" />
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
