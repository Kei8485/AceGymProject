<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="867.0" style="-fx-background-color: #0E1223;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codes.acegym.DashboardController">
    <stylesheets>
        <URL value="@../../Css/styles2.css" />
    </stylesheets>
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
            </padding>
            <children>
                <Label styleClass="labelText" text="Dashboard" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="40.0" />
                    </font>
                </Label>

                <VBox spacing="15.0" style="-fx-background-color: #192037; -fx-background-radius: 15;" styleClass="report-container">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="15.0" />
                    </padding>
                    <children>
                        <Label styleClass="labelText" text="Report Overview" textFill="#ee4f5c">
                            <font>
                                <Font size="24.0" />
                            </font>
                        </Label>
                        <HBox alignment="CENTER" spacing="20.0">
                            <children>
                                <VBox alignment="CENTER" prefHeight="140.0" prefWidth="180.0" spacing="5.0" style="-fx-background-color: #394058; -fx-background-radius: 10;" styleClass="card">
                                    <children>
                                        <Label styleClass="labelText" text="Renewals Due" textFill="#a8a8a8">
                                            <font>
                                                <Font name="System Bold" size="18.0" />
                                            </font>
                                        </Label>
                                        <Label text="10" textFill="WHITE">
                                            <font>
                                                <Font name="System Bold" size="48.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" prefHeight="140.0" prefWidth="180.0" spacing="5.0" style="-fx-background-color: #394058; -fx-background-radius: 10;" styleClass="card">
                                    <children>
                                        <Label styleClass="labelText" text="New Members" textFill="#a8a8a8">
                                            <font>
                                                <Font name="System Bold" size="18.0" />
                                            </font>
                                        </Label>
                                        <Label text="10" textFill="WHITE">
                                            <font>
                                                <Font name="System Bold" size="48.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER" prefHeight="140.0" prefWidth="180.0" spacing="5.0" style="-fx-background-color: #394058; -fx-background-radius: 10;" styleClass="card">
                                    <children>
                                        <Label styleClass="labelText" text="Staffs" textFill="#a8a8a8">
                                            <font>
                                                <Font name="System Bold" size="18.0" />
                                            </font>
                                        </Label>
                                        <Label text="10" textFill="WHITE">
                                            <font>
                                                <Font name="System Bold" size="48.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #192037; -fx-background-radius: 15;" styleClass="report-container" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <children>
                                <Label styleClass="labelText" text="Members" textFill="#ee4f5c">
                                    <font>
                                        <Font size="22.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #192037; -fx-background-radius: 15;" styleClass="report-container" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <children>
                                <Label styleClass="labelText" text="Coaches/Staff" textFill="#ee4f5c">
                                    <font>
                                        <Font size="22.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>